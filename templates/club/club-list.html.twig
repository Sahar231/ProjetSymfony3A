{% extends 'base.html.twig' %}

{% block title %}club-list{% endblock %}

{% block body %}
<!-- =======================
Page Banner START -->
<section class="py-0">
	<div class="container mb-4">
		<div class="row">
			<div class="col-12">
				{% if is_granted('ROLE_ADMIN') %}
					<a href="{{ path('admin_dashboard') }}" class="btn btn-outline-secondary">
						<i class="bi bi-arrow-left me-2"></i>Retour au Dashboard
					</a>
				{% elseif is_granted('ROLE_INSTRUCTOR') %}
					<a href="{{ path('instructor_dashboard') }}" class="btn btn-outline-secondary">
						<i class="bi bi-arrow-left me-2"></i>Retour au Dashboard
					</a>
				{% elseif is_granted('ROLE_STUDENT') %}
					<a href="{{ path('student_dashboard') }}" class="btn btn-outline-secondary">
						<i class="bi bi-arrow-left me-2"></i>Retour au Dashboard
					</a>
				{% endif %}
			</div>
		</div>
	</div>

	<div class="container">
		<div class="row">
			<div class="col-12">
				<div class="bg-dark p-4 p-sm-5 rounded-3" style="background:url({{ asset('assets/images/pattern/04.png') }}) no-repeat center center; background-size:cover;">
					<div class="row align-items-center">
						<div class="col-sm-6 text-center text-sm-start">
							<div class="d-sm-flex justify-content-between align-items-center">
								<div>
									<h1 class="text-white mb-2">Communauté de Clubs</h1>
									<!-- Breadcrumb -->
									<nav aria-label="breadcrumb">
										<ol class="breadcrumb breadcrumb-dark breadcrumb-dots mb-0 justify-content-center justify-content-sm-start">
											<li class="breadcrumb-item"><a href="{{ path('app_home') }}">Accueil</a></li>
											<li class="breadcrumb-item active" aria-current="page">Clubs</li>
										</ol>
									</nav>
								</div>
								{% if is_granted('ROLE_STUDENT') and not is_granted('ROLE_ADMIN') %}
									<div class="mt-3 mt-sm-0 d-flex gap-2">
										<a href="{{ path('student_dashboard') }}" class="btn btn-outline-light mb-0">
											<i class="bi bi-columns-gap me-2"></i>Mon Dashboard
										</a>
										<a href="{{ path('club_create') }}" class="btn btn-primary mb-0">
											<i class="fas fa-plus me-2"></i>Ajouter un Club
										</a>
									</div>
								{% endif %}
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
<!-- =======================
Page Banner END -->

<!-- =======================
Page content START -->
<section class="py-5">
	<div class="container">
		<div class="row g-4 justify-content-center">
			
			<!-- Main content START -->
			<div class="col-lg-12">

				<!-- Search and select START -->
				<div class="row g-4 align-items-center mb-4">
					<!-- Search -->
					<div class="col-sm-6 col-md-4">
						<form class="rounded position-relative" method="GET">
							<input class="form-control pe-5 bg-transparent" type="search" name="search" value="{{ search }}" placeholder="Rechercher un club..." aria-label="Search">
							<button class="btn bg-transparent px-2 py-0 position-absolute top-50 end-0 translate-middle-y" type="submit"><i class="fas fa-search fs-6 "></i></button>
						</form>
					</div>

					<!-- Select option -->
					<div class="col-sm-6 col-md-3 ms-auto">
						<form method="GET">
							{% if search %}
								<input type="hidden" name="search" value="{{ search }}">
							{% endif %}
							<select class="form-select js-choice border-0 z-index-9 bg-transparent" name="sort" onchange="this.form.submit()" aria-label=".form-select-sm">
								<option value="date_desc" {{ sort == 'date_desc' ? 'selected' : '' }}>Plus récents</option>
								<option value="date_asc" {{ sort == 'date_asc' ? 'selected' : '' }}>Plus anciens</option>
								<option value="name_asc" {{ sort == 'name_asc' ? 'selected' : '' }}>Nom (A-Z)</option>
								<option value="name_desc" {{ sort == 'name_desc' ? 'selected' : '' }}>Nom (Z-A)</option>
							</select>
						</form>
					</div>
				</div>
				<!-- Search and select END -->

				<!-- Club list START -->
				<div class="row g-4">
					{% for club in clubs %}
						<!-- Card item START -->
						<div class="col-md-6 col-xl-4">
							<div class="card shadow h-100">
								<!-- Image -->
								<img src="{{ asset('assets/images/courses/4by3/08.jpg') }}" class="card-img-top" alt="course image">
								
								<!-- Card body -->
								<div class="card-body pb-0">
									<!-- Badge and favorite -->
									<div class="d-flex justify-content-between mb-2">
										<a href="#" class="badge bg-purple bg-opacity-10 text-purple">Communauté</a>
										<a href="#" class="h6 fw-light mb-0"><i class="far fa-heart"></i></a>
									</div>
									<!-- Title -->
									<h5 class="card-title"><a href="{{ path('club_detail', {id: club.id}) }}">{{ club.name }}</a></h5>
									<p class="mb-2 text-truncate-2">{{ club.description|striptags|slice(0, 100) }}...</p>
								</div>

								<!-- Card footer -->
								<div class="card-footer pt-0 pb-3">
									<hr>
									<div class="d-flex justify-content-between align-items-center">
										<div class="d-flex align-items-center">
											<div class="avatar avatar-xs me-2">
												<img class="avatar-img rounded-circle" src="{{ asset('assets/images/avatar/01.jpg') }}" alt="avatar">
											</div>
											<span class="h6 fw-light mb-0">{{ club.creator.fullName|default('Instructeur') }}</span>
										</div>
										<div class="h6 fw-light mb-0">
											<i class="fas fa-users text-orange me-2"></i>{{ club.members|length }}
										</div>
									</div>
									<div class="d-flex gap-2 mt-3">
										<a href="{{ path('club_detail', {id: club.id}) }}" class="btn btn-primary-soft flex-fill mb-0">Voir Détails</a>
										{% if club.events|filter(e => e.status == 'APPROVED')|length > 0 %}
											<a href="{{ path('event_list', {clubId: club.id}) }}" class="btn btn-secondary-soft flex-fill mb-0">Voir les événements</a>
										{% endif %}
									</div>
								</div>
							</div>
						</div>
						<!-- Card item END -->
					{% else %}
						<div class="col-12 text-center py-5">
							<div class="mb-3">
								<i class="fas fa-users fa-4x text-muted opacity-25"></i>
							</div>
							<h4>Aucun club trouvé</h4>
							<p class="text-muted">Essayez de modifier vos critères de recherche.</p>
							<a href="{{ path('club_list') }}" class="btn btn-primary-soft">Afficher tous les clubs</a>
						</div>
					{% endfor %}
				</div>
				<!-- Club list END -->

				<!-- Pagination START -->
				<div class="col-12">
					<nav class="mt-4 d-flex justify-content-center" aria-label="navigation">
						<ul class="pagination pagination-primary-soft d-inline-block d-md-flex rounded mb-0">
							<li class="page-item mb-0"><a class="page-link" href="#" tabindex="-1"><i class="fas fa-angle-double-left"></i></a></li>
							<li class="page-item mb-0 active"><a class="page-link" href="#">1</a></li>
							<li class="page-item mb-0"><a class="page-link" href="#" tabindex="-1"><i class="fas fa-angle-double-right"></i></a></li>
						</ul>
					</nav>
				</div>
				<!-- Pagination END -->

			</div>
			<!-- Main content END -->
		</div><!-- Row END -->
	</div>
</section>
<!-- =======================
Page content END -->
{% endblock %}

