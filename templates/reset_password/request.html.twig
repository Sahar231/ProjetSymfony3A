{% extends 'base.html.twig' %}

{% block title %}Reset your password{% endblock %}

{% block body %}
<section class="p-0 d-flex align-items-center position-relative overflow-hidden">
    <div class="container-fluid">
        <div class="row">
            <!-- Left: Image -->
            <div class="col-12 col-lg-6 d-md-flex align-items-center justify-content-center bg-primary bg-opacity-10 vh-lg-100">
                <div class="p-3 p-lg-5">
                    <img src="{{ asset('assets/images/element/02.svg') }}" class="mt-5" alt="">
                </div>
            </div>

            <!-- Right: Content -->
            <div class="col-12 col-lg-6 m-auto">
                <div class="row my-5">
                    <div class="col-sm-10 col-xl-8 m-auto">
                        <div class="bg-body shadow rounded-3 p-4 p-sm-5">
                            
                            <!-- Title -->
                            <h1 class="fs-2">Forgot Password?</h1>
                            <p class="lead mb-4">Enter your email address and we will send you a link to reset your password.</p>

                            {% for flash_error in app.flashes('reset_password_error') %}
                                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                    {{ flash_error|raw }}
                                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                </div>
                            {% endfor %}

                            {% for message in app.flashes('success') %}
                                <div class="alert alert-success alert-dismissible fade show" role="alert">
                                    {{ message|raw }}
                                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                </div>
                            {% endfor %}

                            <!-- Form -->
                            {{ form_start(requestForm, {'attr': {'novalidate': 'novalidate'}}) }}
                                <div class="text-danger mb-3">
                                    {{ form_errors(requestForm) }}
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Email Address</label>
                                    <div class="input-group input-group-lg">
                                        <span class="input-group-text bg-light rounded-start border-0 text-secondary px-3"><i class="bi bi-envelope-fill"></i></span>
                                        {{ form_widget(requestForm.email, {'attr': {'class': 'form-control border-0 bg-light ps-1', 'placeholder': 'example@email.com'}}) }}
                                        <button class="btn voice-typing-btn rounded-end" type="button" title="Saisie vocale">🎤</button>
                                    </div>
                                    <div class="form-text text-danger">
                                        {{ form_errors(requestForm.email) }}
                                    </div>
                                </div>
                                <div class="d-grid">
                                    <button class="btn btn-primary btn-lg" type="submit">Send Reset Link</button>
                                </div>
                            {{ form_end(requestForm) }}
                            
                            <!-- Links -->
                            <div class="mt-4 text-center">
                                <span>Back to <a href="{{ path('app_login') }}">Sign in</a></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script src="{{ asset('assets/js/voice-typing.js') }}"></script>
{% endblock %}
