<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connexion3a36.Controller.ListeResultatController">
  <top>
    <VBox>
      <ToolBar styleClass="tool-bar">
        <TextField fx:id="searchTF" promptText="Rechercher..." styleClass="search-field large-search" />
        <Button text="Rechercher" fx:id="searchButton" onAction="#handleSearch" styleClass="search-button" />
        <Button text="Rafraîchir" fx:id="refreshButton" onAction="#handleRefresh" styleClass="refresh-button" />
        <Separator />
        <Button text="Ajouter" fx:id="addButton" onAction="#handleAdd" styleClass="add-button" />
        <Button text="Modifier" fx:id="editButton" onAction="#handleEdit" styleClass="edit-button" />
        <Button text="Supprimer" fx:id="deleteButton" onAction="#handleDelete" styleClass="delete-button" />
        <Region fx:id="spacer" />
        <Button text="Retour" fx:id="backButton" onAction="#handleBack" styleClass="back-button" />
      </ToolBar>
      <HBox spacing="8">
        <Label fx:id="alertSuccess" styleClass="alert-success" visible="false" managed="false" />
        <Label fx:id="alertError" styleClass="alert-error" visible="false" managed="false" />
      </HBox>
    </VBox>
  </top>
  <center>
    <TableView fx:id="resultatTable" styleClass="modern-table">
      <columns>
        <TableColumn fx:id="colId" text="ID" />
        <TableColumn fx:id="colScore" text="Score" />
        <TableColumn fx:id="colCreatedAt" text="Créé le" />
      </columns>
    </TableView>
  </center>
</BorderPane>
